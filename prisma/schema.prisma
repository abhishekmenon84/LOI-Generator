generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  accounts            Account[]
  sessions            Session[]
  memberships         Membership[]
  dealsCreated        Deal[]      @relation("DealCreator")
  dealSharesReceived  DealShare[] @relation("DealShareRecipient")
  dealSharesGranted   DealShare[] @relation("DealShareGrantor")
}

model Organization {
  id                   String   @id @default(cuid())
  name                 String
  accountType          String   @default("individual") // "individual" | "real_estate_agency" | "company" | "corporation"
  isPersonal           Boolean  @default(true)
  planTier             String   @default("trial") // "trial" | "tier_1_10" | "tier_11_30" | "tier_31_50" | "enterprise" | "expired"
  trialEndsAt          DateTime?
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  memberships Membership[]
  deals       Deal[]
}

model Membership {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId  String
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role   String @default("member") // "admin" | "member"

  createdAt DateTime @default(now())

  @@unique([userId, orgId])
  @@index([orgId])
}

model ProcessedWebhookEvent {
  id          String   @id // Stripe event.id — dedup key
  processedAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Deal {
  id              String   @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdBy       User     @relation("DealCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  name            String
  documentType    String   @default("purchase_loi")
  formData        Json
  stage           String   @default("draft") // "draft" | "active" | "pending" | "closed"
  locked          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shares            DealShare[]
  signatureRequests SignatureRequest[]

  @@index([orgId])
  @@index([createdByUserId])
}

model DealShare {
  id              String   @id @default(cuid())
  dealId          String
  deal            Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  grantedToUserId String
  grantedTo       User     @relation("DealShareRecipient", fields: [grantedToUserId], references: [id], onDelete: Cascade)
  grantedByUserId String
  grantedBy       User     @relation("DealShareGrantor", fields: [grantedByUserId], references: [id], onDelete: Cascade)
  permission      String   @default("read") // "read" | "write"
  createdAt       DateTime @default(now())

  @@unique([dealId, grantedToUserId])
  @@index([dealId])
  @@index([grantedToUserId])
}

model SignatureRequest {
  id          String   @id @default(cuid())
  dealId      String
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  status      String   @default("pending") // "pending" | "fully_executed" | "voided"
  verifyCode  String   @unique
  createdByUserId String
  finalDocumentHash String?
  createdAt   DateTime @default(now())
  voidedAt    DateTime?

  signers SignerSlot[]

  @@index([dealId])
}

model SignerSlot {
  id             String   @id @default(cuid())
  requestId      String
  request        SignatureRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  kind           String   @default("signer") // "signer" | "notify_only"
  role           String
  roleOtherLabel String?
  name           String
  email          String
  signingToken   String?  @unique
  tokenUsedAt    DateTime?
  createdAt      DateTime @default(now())

  signatureEvent SignatureEvent?

  @@index([requestId])
}

model SignatureEvent {
  id                String   @id @default(cuid())
  signerSlotId      String   @unique
  signerSlot        SignerSlot @relation(fields: [signerSlotId], references: [id], onDelete: Cascade)
  signatureImageUrl String
  documentHash      String
  userAgent         String
  screenInfo        String
  timezoneOffset    Int
  ipAddress         String
  geoCountry        String?
  geoRegion         String?
  geoCity           String?
  signedAt          DateTime @default(now())
}
